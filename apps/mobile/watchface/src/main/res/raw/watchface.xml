<?xml version="1.0" encoding="utf-8"?>
<!--
  GlycemicGPT Watch Face Format (WFF v2)

  Minimal version for Watch Face Push API validation testing.
  Displays time, date, and BG complication.
-->
<WatchFace clipShape="CIRCLE" width="450" height="450">

    <Metadata key="CLOCK_TYPE" value="DIGITAL"/>
    <Metadata key="PREVIEW_TIME" value="10:08:32"/>

    <Scene backgroundColor="#ff000000">

        <!-- Time Display: bold in active, thin in ambient to reduce burn-in -->
        <DigitalClock x="0" y="150" width="450" height="100">
            <TimeText format="h:mm" hourFormat="SYNC_TO_DEVICE" align="CENTER"
                x="0" y="0" width="450" height="100">
                <Font family="SYNC_TO_DEVICE" size="72" weight="BOLD"
                    color="#ffffffff">
                    <Variant mode="AMBIENT" target="weight" value="THIN"/>
                    <Variant mode="AMBIENT" target="color" value="#99ffffff"/>
                </Font>
            </TimeText>
        </DigitalClock>

        <!-- GlycemicGPT label: hidden in ambient to reduce burn-in -->
        <PartText x="125" y="350" width="200" height="30" alpha="255">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="14" weight="BOLD"
                    color="#663B82F6">GlycemicGPT</Font>
            </Text>
        </PartText>

    </Scene>

</WatchFace>
